# Copy to `.env.local` in this folder. Keys must come from YOUR app in the Clerk dashboard
# (https://dashboard.clerk.com → select application → API Keys). Placeholder values will not work.
#
# Clerk Authentication (use your app's keys from the Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# API Configuration
# Backend API URL
NEXT_PUBLIC_API_URL="http://localhost:3001"
